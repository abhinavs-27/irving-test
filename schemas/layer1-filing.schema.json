{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://irving.local/schemas/layer1-filing.schema.json",
  "title": "SEC Layer 1 filing graph",
  "type": "object",
  "required": ["entity_registry", "block_registry", "events", "relationships"],
  "additionalProperties": true,
  "properties": {
    "entity_registry": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entityRecord" }
    },
    "block_registry": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/blockRecord" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/eventRecord" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationshipRecord" }
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/sectionNode" }
    }
  },
  "$defs": {
    "entityRecord": {
      "type": "object",
      "required": ["kind", "canonical_name", "aliases"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["organization", "person"]
        },
        "canonical_name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "blockRecord": {
      "type": "object",
      "required": ["id", "type", "semantic_role", "paragraph_ids"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "structural",
            "pricing_mechanism",
            "constraint",
            "termination",
            "regulatory_disclosure"
          ],
          "description": "Use regulatory_disclosure for Item disclosure blocks; semantic_role uses disclosure."
        },
        "semantic_role": {
          "type": "string",
          "enum": ["structural", "pricing", "constraint", "termination", "disclosure"]
        },
        "paragraph_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "pricing_model": { "$ref": "#/$defs/pricingModel" }
      }
    },
    "pricingModel": {
      "type": "object",
      "required": ["type", "method", "modes"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "vwap_discount" },
        "method": { "type": "string", "const": "VWAP" },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pricingMode" }
        }
      }
    },
    "pricingMode": {
      "type": "object",
      "required": ["name", "vwap_window"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "enum": ["regular_purchase", "intraday_purchase"]
        },
        "vwap_window": {
          "type": "string",
          "enum": ["full_session", "intraday", "intraday_segments"]
        },
        "discount_percent": { "type": "number" },
        "volume_threshold_truncation": { "type": "boolean" },
        "excludes_open_close": { "type": "boolean" },
        "multi_window": { "type": "boolean" }
      }
    },
    "eventRecord": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "label",
        "primary_entity_id",
        "counterparty_entity_ids",
        "agreement_types",
        "source_block_ids"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^event:"
        },
        "kind": {
          "type": "string",
          "enum": ["agreement_execution", "agreement_termination", "commencement"]
        },
        "label": { "type": "string" },
        "primary_entity_id": {
          "type": "string",
          "pattern": "^org:"
        },
        "counterparty_entity_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^org:" }
        },
        "agreement_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_block_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "as_of_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "relationshipRecord": {
      "type": "object",
      "required": ["type", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["defines", "constrains", "governs", "references", "triggers"]
        },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "sectionNode": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "atomicKind": { "type": "string" },
        "facts": { "$ref": "#/$defs/factsV2" },
        "signals": { "type": "object" },
        "entities": { "type": "object" },
        "block_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "object" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/sectionNode" }
        }
      }
    },
    "factsV2": {
      "type": "object",
      "required": [
        "percentages",
        "dollar_amounts",
        "share_counts",
        "price_thresholds",
        "dates",
        "time_windows"
      ],
      "properties": {
        "percentages": { "type": "array", "items": { "type": "number" } },
        "dollar_amounts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "currency"],
            "properties": {
              "value": { "type": "number" },
              "currency": { "type": "string", "const": "USD" }
            }
          }
        },
        "share_counts": { "type": "array", "items": { "type": "number" } },
        "price_thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "currency"],
            "properties": {
              "value": { "type": "number" },
              "currency": { "type": "string", "const": "USD" }
            }
          }
        },
        "dates": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "time_windows": { "type": "array", "items": { "type": "object" } },
        "percentage_decimals": {
          "type": "array",
          "description": "Optional normalized decimals (0–1) parallel to percentages",
          "items": { "type": "number" }
        }
      }
    }
  }
}
